# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=gestionelogistica

# JWT Configuration
# IMPORTANT: Change this to a strong, unique secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3001
PORT=3001

# Security
BCRYPT_SALT_ROUNDS=12

# Session Configuration
SESSION_CLEANUP_INTERVAL=3600000
# Cleanup interval in milliseconds (1 hour = 3600000ms)

# Development/Production Environment
NODE_ENV=development

# --- Backup / mysqldump (vedi docs/backup-sistema-e-client-mysql.md) ---
# Client MySQL 8+ consigliato per cloud (caching_sha2_password, SSL)
# MYSQL_BIN=C:\Program Files\MySQL\MySQL Server 8.4\bin
# DB_GESTIONE_HOST= DB_GESTIONE_PORT= DB_GESTIONE_USER= DB_GESTIONE_PASS= DB_GESTIONE_NAME=
# DB_VIAGGI_HOST= DB_VIAGGI_PORT= DB_VIAGGI_USER= DB_VIAGGI_PASS= DB_VIAGGI_NAME=
# MySQL cloud: DB_VIAGGI_SSL=true (verifica CA disattivata di default; per strict: DB_VIAGGI_SSL_REJECT_UNAUTHORIZED=true)
# MYSQL_HOST= MYSQL_PORT= MYSQL_USER= MYSQL_PASSWORD=
# BACKUP_MYSQL_SSL=true
# BACKUP_MYSQLDUMP_SSL_ARGS=--ssl-mode=REQUIRED

# Instructions:
# 1. Copy this file to .env
# 2. Update the database credentials
# 3. Generate a strong JWT secret (at least 32 characters)
# 4. Adjust other settings as needed for your environment